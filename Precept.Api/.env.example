# ─────────────────────────────────────────────────────────────
#  Precept API — Environment Variables
# ─────────────────────────────────────────────────────────────
#  Copy this file to .env and fill in the values.
#  .env is gitignored and should NEVER be committed.
# ─────────────────────────────────────────────────────────────

# PostgreSQL connection string (no password hardcoded here; use a secret).
# Example: Host=db;Database=precept_db;Username=postgres;Password=<strong-secret>
ConnectionStrings__DefaultConnection=Host=localhost;Database=precept_db;Username=postgres;Password=replace-with-strong-password

# JWT signing key — must be at least 32 characters (256 bits) for HMAC-SHA256.
# Generate one with: openssl rand -base64 64
JWT_SECRET_KEY=replace-with-cryptographically-strong-secret-key

# Allowed ASP.NET Core request hosts (semicolon-separated).
# Use the production domain(s) here. Empty or "*" allows any host (not recommended).
ALLOWED_HOSTS=app.example.com;www.example.com

# Comma-separated list of origins allowed by the production CORS policy.
# Must match the deployed frontend URL(s).
CORS_ORIGINS=https://app.example.com,https://www.example.com

# Set to true to apply EF Core migrations on startup (use with caution in production).
RunMigrationsOnStartup=false
